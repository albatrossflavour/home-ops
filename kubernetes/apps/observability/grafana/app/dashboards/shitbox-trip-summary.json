      "targets": [
        {
          "expr": "increase(shitbox_events_total[$__range])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 60,
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 14,
        "x": 0,
        "y": 20
      },
      "title": "Speed & Altitude",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Speed"
            },
            "properties": [
              {
                "id": "unit",
                "value": "velocitykmh"
