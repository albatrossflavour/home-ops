  "title": "Shitbox Rally \u2014 Trip Summary",
  "uid": "shitbox-trip-summary",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "title": "$day",
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;gap:1rem;align-items:center;\"><img src=\"https://shit-of-theseus.com/build/car-front.jpg\" style=\"max-height:90px;border-radius:6px;\"/><div style=\"flex:1;\"><div style=\"color:#8b949e;font-size:0.8rem;\">DRIVER STORY</div><div style=\"font-size:1.1rem;color:#e6edf3;\">${day}</div><div style=\"color:#8b949e;font-size:0.85rem;margin-top:0.4rem;\">Set the time range (top right) to the day's window for accurate stats. Future: bind automatically from this picker.</div></div></div>"
      },
      "transparent": true
    },
    {
      "id": 10,
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "title": "Distance",
      "description": "Day distance. TODO: needs a `shitbox_trip_distance_km` cumulative metric (or integrate `shitbox_spd` over the time range). Currently shown as a placeholder.",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthkm",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#f0dbb8"
          },
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": {
                  "text": "\u2014"
                }
              },
              "type": "special"
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max_over_time(shitbox_spd[$__range]) * 0",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "pluginVersion": "10.1.5"
    },
    {
      "id": 11,
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "title": "Time Moving",
      "description": "Time spent moving (>5 km/h). Computed as a fraction of samples above the threshold.",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "fixed",
            "fixedColor": "#f0dbb8"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count_over_time((shitbox_spd > 5)[$__range:]) * 60",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "title": "Top Speed",
      "description": "Highest speed observed during the day. Filtered to realistic values (\u2264 180 km/h) \u2014 raw `shitbox_spd` can spike past 1000 km/h during GPS multipath / cold-fix events; the Laser is not breaking the sound barrier on the Eyre Highway.",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "max"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "color": {
            "mode": "fixed",
            "fixedColor": "#f0dbb8"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max_over_time((shitbox_spd < 180)[$__range:])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "title": "Peak G",
      "description": "Largest g-force magnitude observed during the day, regardless of axis. Clamped to \u22645g \u2014 anything above is an IMU bench-glitch, not a real road event (detector thresholds sit at 0.35\u20130.45g, hard real-world hits stay under 3g).",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "max"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "#da3633"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max_over_time((sqrt(shitbox_ax^2 + shitbox_ay^2 + shitbox_az^2) < 5)[$__range:])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 4
      },
      "title": "Events",
      "description": "Total events captured during the day (high g, hard brake, big corner, rough road, manual, boot, TPMS).",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "fixed",
            "fixedColor": "#1f6feb"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(shitbox_events_total[$__range]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "geomap",
      "gridPos": {
        "h": 12,
        "w": 14,
        "x": 0,
        "y": 8
      },
      "title": "Route \u2014 $day",
      "description": "GPS trail for the day. Future: overlay event pins coloured by type (HIGH_G red, BIG_CORNER amber, HARD_BRAKE red, ROUGH_ROAD purple, MANUAL green) and fuel stops as fuel-pump icons.",
