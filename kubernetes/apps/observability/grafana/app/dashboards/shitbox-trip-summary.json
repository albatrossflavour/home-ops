          "mouseWheelZoom": true,
          "showAttribution": true,
          "showScale": true,
          "showMeasure": false,
          "showDebug": false
        },
        "basemap": {
          "type": "default",
          "name": "Layer 0"
        },
        "layers": [
          {
            "type": "markers",
            "name": "GPS trail",
