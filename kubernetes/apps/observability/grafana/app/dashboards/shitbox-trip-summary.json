          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(shitbox_driver_time_seconds{driver=~\"$driver\"}[$__range])",
          "legendFormat": "{{driver}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "type": "barchart",
      "gridPos": {
        "h": 6,
        "w": 10,
        "x": 14,
        "y": 14
      },
      "title": "Events by Type",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "orientation": "horizontal",
        "stacking": "none",
        "legend": {
          "displayMode": "hidden"
