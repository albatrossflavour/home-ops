        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "#da3633",
        "name": "Shitbox Events",
        "target": { "expr": "", "interval": "", "refId": "Anno", "tags": ["shitbox"], "type": "tags" }
      }
