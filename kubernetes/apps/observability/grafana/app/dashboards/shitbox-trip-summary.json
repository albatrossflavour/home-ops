        {
          "expr": "shitbox_lon",
          "legendFormat": "lon",
          "refId": "B"
        }
      ]
    },
    {
      "id": 40,
      "type": "piechart",
      "gridPos": {
        "h": 6,
        "w": 10,
        "x": 14,
        "y": 8
      },
      "title": "Drive Time by Driver",
      "datasource": {
        "type": "prometheus",
        "uid": "shitbox"
      },
      "options": {
        "legend": {
          "displayMode": "table",
